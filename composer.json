{
    "name": "typicms/core",
    "description": "The core package of TypiCMS, containing the base architecture, services, and shared components used across all modules.",
    "license": "MIT",
    "authors": [
        {
            "name": "Samuel De Backer",
            "email": "sdebacker@gmail.com"
        }
    ],
    "require": {
        "laravel/framework": "~13.0"
    },
    "autoload": {
        "psr-4": {
            "TypiCMS\\Modules\\Core\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "TypiCMS\\Modules\\Core\\Providers\\ModuleServiceProvider",
                "TypiCMS\\Modules\\Core\\Providers\\TranslationsServiceProvider"
            ]
        }
    }
}
